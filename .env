# ==========================================================
# MAGMA API Telegram Music Bot - Environment Variables
# ==========================================================

# ----------------------------------------------------------
# 1. Telegram & Bot Setup
# ----------------------------------------------------------
API_ID=12345678
API_HASH=dummy_api_hash_1234567890abcdef
BOT_TOKEN=1234567890:AADummyBotTokenExampleReplaceMe


# ----------------------------------------------------------
# 2. Database & IDs
# ----------------------------------------------------------
MONGO_DB_URI=mongodb+srv://dummy_user:dummy_password@cluster.mongodb.net/dummydb
OWNER_ID=123456789
LOGGER_ID=-1001234567890


# ----------------------------------------------------------
# 3. Assistant Setup (Pyrogram String Session)
# ----------------------------------------------------------
STRING_SESSION=dummy_pyrogram_string_session_replace_this
# STRING_SESSION2=
# STRING_SESSION3=


# ----------------------------------------------------------
# 4. Branding & Links (MAGMA)
# ----------------------------------------------------------
BOT_NAME=MAGMA
SUPPORT_CHANNEL=https://t.me/MAGMA_SUPPORT
SUPPORT_CHAT=https://t.me/MAGMA_SUPPORT
GITHUB_REPO=https://github.com/example/magma


# ----------------------------------------------------------
# 5. MAGMA Custom API Setup
# ----------------------------------------------------------
ANYSNAP_API_URL=http://127.0.0.1:8000
ENABLE_API=True

PORT=8080


# ----------------------------------------------------------
# 6. Limits & Extra Settings
# ----------------------------------------------------------
DURATION_LIMIT=300
QUEUE_LIMIT=30
PLAYLIST_LIMIT=20
AUTO_END=False
AUTO_LEAVE=False


# ----------------------------------------------------------
# 7. Images & Thumbnails (MAGMA UI)
# ----------------------------------------------------------
DEFAULT_THUMB=https://example.com/magma_thumb.jpg
PING_IMG=https://example.com/magma_ping.jpg
START_IMG=https://example.com/magma_start.jpg
RADIO_IMG=https://example.com/magma_radio.jpg